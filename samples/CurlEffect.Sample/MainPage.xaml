<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CurlEffect.Controls;assembly=CurlEffect"
             x:Class="CurlEffect.MainPage"
             BackgroundColor="#2B2B2B">

    <ContentPage.Resources>
        <!-- Compact buttons so several fit per row, and a small margin gives spacing inside the
             wrapping FlexLayouts (which have no Spacing of their own). -->
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="Caption" TargetType="Label">
            <Setter Property="TextColor" Value="#AAAAAA" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
        <!-- Light top navigation buttons. -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BackgroundColor" Value="#ECECEC" />
            <Setter Property="TextColor" Value="#2B2B2B" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto" Padding="16">

        <Border Grid.Row="0"
                StrokeShape="RoundRectangle 6"
                StrokeThickness="0"
                BackgroundColor="#3A3A3A">
            <controls:CurlView x:Name="Curl"
                               ItemsSource="{Binding Pages}"
                               CurrentIndex="{Binding Index, Mode=TwoWay}"
                               TurnSpeed="{Binding Speed}"
                               EdgeInset="24"
                               PageChangedCommand="{Binding PageChangedCommand}" />
        </Border>

        <!-- Controls can grow taller than a phone allows once they wrap, so let them scroll. -->
        <ScrollView Grid.Row="1" Padding="0,12,0,0" MaximumHeightRequest="320">
            <VerticalStackLayout Spacing="4">

                <!-- Top navigation row: light buttons, centered. -->
                <FlexLayout Wrap="Wrap" JustifyContent="Center" AlignItems="Center">
                    <Button Text="◀ Back"
                            Style="{StaticResource NavButton}"
                            Command="{Binding Source={x:Reference Curl}, Path=PreviousCommand}" />
                    <Label Text="{Binding PageLabel}"
                           TextColor="White"
                           VerticalOptions="Center"
                           WidthRequest="90"
                           HorizontalTextAlignment="Center" />
                    <Button Text="Next ▶"
                            Style="{StaticResource NavButton}"
                            Command="{Binding Source={x:Reference Curl}, Path=NextCommand}" />
                </FlexLayout>

                <!-- Start / End / Stop / Speed on one line. -->
                <FlexLayout Wrap="Wrap" JustifyContent="Center" AlignItems="Center">
                    <Button Text="⏪ Start"
                            Command="{Binding Source={x:Reference Curl}, Path=AnimateCommand}"
                            CommandParameter="-99" />
                    <Button Text="⏩ End"
                            Command="{Binding Source={x:Reference Curl}, Path=AnimateCommand}"
                            CommandParameter="99" />
                    <Button Text="Stop ■"
                            Command="{Binding Source={x:Reference Curl}, Path=StopAnimationCommand}" />
                    <Picker Title="Speed"
                            WidthRequest="100"
                            TextColor="White"
                            TitleColor="#AAAAAA"
                            ItemsSource="{Binding Speeds}"
                            SelectedItem="{Binding Speed, Mode=TwoWay}" />
                </FlexLayout>

                <Label Text="AnimateFrom" Style="{StaticResource Caption}" />
                <FlexLayout Wrap="Wrap" JustifyContent="Center" AlignItems="Center">
                    <Button Text="↗ TopRight → End"
                            Command="{Binding Source={x:Reference Curl}, Path=AnimateFromCommand}"
                            CommandParameter="TopRight,99" />
                    <Button Text="↘ BottomRight → End"
                            Command="{Binding Source={x:Reference Curl}, Path=AnimateFromCommand}"
                            CommandParameter="BottomRight,99" />
                    <Button Text="↙ BottomLeft → Start"
                            Command="{Binding Source={x:Reference Curl}, Path=AnimateFromCommand}"
                            CommandParameter="BottomLeft,-99" />
                </FlexLayout>

                <Label Text="Jump (no intermediates)" Style="{StaticResource Caption}" />
                <FlexLayout Wrap="Wrap" JustifyContent="Center" AlignItems="Center">
                    <Button Text="⏮ To Start"
                            Command="{Binding Source={x:Reference Curl}, Path=AnimateToStartCommand}" />
                    <Button Text="⏭ To End"
                            Command="{Binding Source={x:Reference Curl}, Path=AnimateToEndCommand}" />
                </FlexLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
